# Copy to .env.local (dev) or set these in docker-compose / your environment.

# Path to your LanCache access.log
LOG_PATH=/path/to/lancache/logs/access.log

# Where the SQLite DB lives. The Steam depot mapping (~100MB) and depot caches
# are stored in this same directory, so point it at a persistent volume.
DB_PATH=./data/lancache.db

# IPs/prefixes hidden from stats by default (prefill traffic from the cache host,
# which misses heavily and skews real client numbers). Comma-separated.
# Entries ending in "." or ":" are treated as prefixes (e.g. "172." = docker bridge).
# Toggle on/off live in the UI.
EXCLUDE_IPS=127.0.0.1,::1,172.,localhost

# Your lancache cache retention window in days (match your CACHE_MAX_AGE).
# Used to estimate which games are "likely still cached".
CACHE_MAX_AGE_DAYS=60

# Server port
PORT=3000

# --- Security (optional, recommended when others can reach the dashboard) ---

# Admin key. When set, the "Ingest Logs" and "Update Depots" actions require it.
# Viewers can still see all stats; only these mutating actions are locked.
# Enter it once via the "Admin" button in the UI. Leave blank to keep actions open.
ADMIN_API_KEY=

# Full-site HTTP Basic Auth (stricter). When BOTH are set, nobody can view the
# dashboard without these credentials. Leave blank for open viewing on your LAN.
DASHBOARD_USER=
DASHBOARD_PASSWORD=

